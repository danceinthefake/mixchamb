# Environment variables to paste into the Dokploy application's
# Environment tab. Dokploy stores these encrypted in its own
# database; this file is just a reference of what to fill in.
# Never commit a filled-in version of this file.

# --- App ---------------------------------------------------------
SECRET_KEY_BASE=REPLACE_WITH_OUTPUT_OF_MIX_PHX_GEN_SECRET
PHX_HOST=REPLACE_WITH_PUBLIC_HOSTNAME
PORT=4000
ADMIN_USER=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN_OR_LEAVE_BLANK

# --- Database ----------------------------------------------------
# Dokploy injects DATABASE_URL when you link the app to a Dokploy
# Postgres service (see README). The connection string will look
# like ecto://mixchamb:<pw>@<service-name>:5432/mixchamb_prod.
# You don't fill this in manually if you use Dokploy's linked
# database. If you bring your own Postgres, set it explicitly:
#
# DATABASE_URL=ecto://mixchamb:REPLACE_WITH_DB_PASSWORD@<host>/mixchamb_prod

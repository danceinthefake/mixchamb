# Cloudflare Tunnel config — copy to /etc/cloudflared/config.yml,
# replace the placeholders, then `systemctl restart cloudflared`.
#
# tunnel UUID + credentials path come from `cloudflared tunnel create`
# (see bootstrap.sh step 7).

tunnel: REPLACE_WITH_TUNNEL_UUID
credentials-file: /etc/cloudflared/REPLACE_WITH_TUNNEL_UUID.json

ingress:
  - hostname: REPLACE_WITH_PUBLIC_HOSTNAME
    service: http://localhost:4000
  - service: http_status:404

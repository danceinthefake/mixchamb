# App runtime env — install at /etc/mixchamb.env (chmod 600,
# owned root:root). Loaded by the mixchamb container via the
# Quadlet `EnvironmentFile=` directive.

DATABASE_URL=ecto://mixchamb:REPLACE_WITH_DB_PASSWORD@postgres/mixchamb_prod
SECRET_KEY_BASE=REPLACE_WITH_OUTPUT_OF_MIX_PHX_GEN_SECRET
PHX_HOST=REPLACE_WITH_PUBLIC_HOSTNAME
PORT=4000
ADMIN_USER=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN_OR_LEAVE_BLANK

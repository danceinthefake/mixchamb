# Container-runtime env shared by postgres + cloudflared.
# Install at /etc/mixchamb-podman.env (chmod 600, root:root).
#
# Kept separate from /etc/mixchamb.env so the Postgres password
# and Cloudflare tunnel token don't get sourced into the
# Phoenix app's environment, where they'd be visible via the
# BEAM's /env endpoint to anyone with admin access.

POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_WITH_TUNNEL_TOKEN

# For the OnFailure notify-telegram@.service template (same
# pattern as linux-host/) — only needed if you're wiring up
# Telegram alerting for crashed containers.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_NEGATIVE_GROUP_CHAT_ID

# Copy to .env (same directory) and fill in. Never commit .env.
# docker compose --env-file .env up -d --build

# --- App ---------------------------------------------------------
SECRET_KEY_BASE=REPLACE_WITH_OUTPUT_OF_MIX_PHX_GEN_SECRET
PHX_HOST=REPLACE_WITH_PUBLIC_HOSTNAME
ADMIN_USER=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN_OR_LEAVE_BLANK

# --- Postgres ----------------------------------------------------
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# --- Cloudflare Tunnel -------------------------------------------
# Create a tunnel in the Cloudflare Zero Trust dashboard, route
# the public hostname to http://app:4000, copy the printed token.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_WITH_TUNNEL_TOKEN

# --- Backups (optional; remove the backup service from compose
# if you handle backups elsewhere) -------------------------------
B2_BUCKET=mixchamb-backups
B2_APPLICATION_KEY_ID=REPLACE_WITH_B2_KEY_ID
B2_APPLICATION_KEY=REPLACE_WITH_B2_APPLICATION_KEY
HEALTHCHECKS_BACKUP_URL=https://hc-ping.com/REPLACE_WITH_UUID

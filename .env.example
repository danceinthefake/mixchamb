# Copy to .env.local and fill in. Loaded via `source .env.local` or
# direnv before running `mix phx.server`.

# Cloudflare R2 (S3-compatible). Create an R2 bucket + an API token
# with read+write scope on that bucket. The endpoint host pattern is
# <account_id>.r2.cloudflarestorage.com.
R2_ENDPOINT_HOST=<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mixwave-dev
